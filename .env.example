# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=syyaimeiq
POSTGRES_USER=miq_user
POSTGRES_PASSWORD=change_this_strong_password
DATABASE_URL=postgresql+asyncpg://miq_user:changeme@localhost:5432/syyaimeiq

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace_with_64_char_random_string

# ── Domain ────────────────────────────────────────────────────────────────────
BASE_DOMAIN=syyaimeiq.com
APP_URL=https://syyaimeiq.com
VITE_BASE_DOMAIN=syyaimeiq.com
VITE_PUBLIC_API=https://syyaimeiq.com

# ── Local Dev (override tenant via header instead of subdomain) ───────────────
# VITE_TENANT_SLUG=demo

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Redis (for Celery background tasks) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Get from https://dashboard.razorpay.com/app/webhooks
# Set webhook URL to: https://syyaimeiq.com/api/v1/billing/webhook
# Events: payment.captured, payment_link.paid, subscription.activated,
#         subscription.charged, subscription.halted, subscription.cancelled
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Optional: Create a Plan at https://dashboard.razorpay.com/app/subscriptions/plans
# Product: Syyaim EIQ Growth Plan, Amount: 12999, Period: monthly
# Leave blank to use one-time payment links instead of subscriptions
RAZORPAY_PLAN_ID=plan_...

# ── Email (transactional) ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@syyaimeiq.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=noreply@syyaimeiq.com

# ── Super Admin ───────────────────────────────────────────────────────────────
SUPERADMIN_SECRET=replace_with_strong_random_secret

# ── Trial ─────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14

